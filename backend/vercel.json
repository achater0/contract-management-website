{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/login", "dest": "server.js" },
    { "src": "/assets/(.*)", "dest": "public/assets/$1" },
    { "src": "/favicon.ico", "dest": "public/favicon.ico" },
    { "src": "/(.*)", "dest": "public/index.html" }
  ]
}